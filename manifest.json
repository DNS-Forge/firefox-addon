{
  "manifest_version": 3,
  "name": "DNS Forge",
  "version": "0.9.3",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "menus",
    "webRequest",
    "webRequestBlocking"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "host_permissions": [
    "https://api.nextdns.io/*",
    "https://test.nextdns.io/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://my.nextdns.io/*"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{56fda99b-4dd4-4a4a-a413-00ff1c2cffd8}"
    }
  }
}
